<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgMain"
    android:orientation="vertical">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/search_bar_height"
        android:background="@color/bgWhite"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="设置"
            android:textColor="@color/textPrimary"
            android:textSize="@dimen/text_18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- 账号管理 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bgWhite"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="账号管理"
                    android:textColor="@color/textHint"
                    android:textSize="@dimen/text_12sp" />

                <TextView
                    android:id="@+id/item_edit_profile"
                    style="@style/SettingsItem"
                    android:text="编辑个人资料" />

                <View style="@style/DividerLine" />

                <TextView
                    android:id="@+id/item_change_phone"
                    style="@style/SettingsItem"
                    android:text="修改手机号" />

                <View style="@style/DividerLine" />

                <TextView
                    android:id="@+id/item_change_password"
                    style="@style/SettingsItem"
                    android:text="修改密码" />
            </LinearLayout>

            <!-- 消息通知 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/bgWhite"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="消息通知"
                    android:textColor="@color/textHint"
                    android:textSize="@dimen/text_12sp" />

                <TextView
                    android:id="@+id/item_push_notify"
                    style="@style/SettingsItem"
                    android:text="推送通知设置" />

                <View style="@style/DividerLine" />

                <TextView
                    android:id="@+id/item_msg_sound"
                    style="@style/SettingsItem"
                    android:text="消息声音" />
            </LinearLayout>

            <!-- 通用设置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/bgWhite"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="通用"
                    android:textColor="@color/textHint"
                    android:textSize="@dimen/text_12sp" />

                <TextView
                    android:id="@+id/item_language"
                    style="@style/SettingsItem"
                    android:text="语言设置" />

                <View style="@style/DividerLine" />

                <TextView
                    android:id="@+id/item_cache"
                    style="@style/SettingsItem"
                    android:text="清理缓存" />

                <View style="@style/DividerLine" />

                <TextView
                    android:id="@+id/item_about"
                    style="@style/SettingsItem"
                    android:text="关于我们" />
            </LinearLayout>

            <!-- 退出登录 -->
            <TextView
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_white_card"
                android:gravity="center"
                android:text="退出登录"
                android:textColor="@color/tagRed"
                android:textSize="@dimen/text_16sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
