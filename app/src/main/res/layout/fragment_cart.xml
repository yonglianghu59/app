<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgMain"
    android:orientation="vertical">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/search_bar_height"
        android:background="@color/bgWhite"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cart_title"
            android:textColor="@color/textPrimary"
            android:textSize="@dimen/text_18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_clear_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="@string/cart_clear"
            android:textColor="@color/textSecondary"
            android:textSize="@dimen/text_14sp" />
    </LinearLayout>

    <!-- 配送提示栏 -->
    <LinearLayout
        android:id="@+id/layout_delivery_hint"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_white_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_profile_delivery" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/cart_free_delivery_hint"
            android:textColor="@color/textSecondary"
            android:textSize="@dimen/text_12sp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:alpha="0.5"
            android:src="@drawable/ic_arrow_right" />
    </LinearLayout>

    <!-- 购物车商品列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_cart_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <!-- 推荐商品区域 -->
    <LinearLayout
        android:id="@+id/layout_recommend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bgWhite"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            android:text="@string/cart_recommend"
            android:textColor="@color/textPrimary"
            android:textSize="@dimen/text_15sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_recommend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
    </LinearLayout>

    <!-- 底部结算栏 -->
    <LinearLayout
        android:id="@+id/layout_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cart_bar_height"
        android:background="@color/bgWhite"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="4dp">

        <!-- 全选 -->
        <LinearLayout
            android:id="@+id/layout_select_all"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_select_all"
                android:layout_width="@dimen/icon_large"
                android:layout_height="@dimen/icon_large"
                android:src="@drawable/ic_checkbox_unchecked" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/cart_select_all"
                android:textColor="@color/textSecondary"
                android:textSize="@dimen/text_13sp" />
        </LinearLayout>

        <!-- 合计金额 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical|end"
            android:orientation="vertical"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/tv_total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/yuan"
                android:textColor="@color/priceRed"
                android:textSize="@dimen/text_18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 去结算按钮 -->
        <TextView
            android:id="@+id/tv_go_settle"
            android:layout_width="100dp"
            android:layout_height="36dp"
            android:background="@drawable/selector_orange_button"
            android:gravity="center"
            android:text="@string/cart_go_settle"
            android:textColor="@color/textWhite"
            android:textSize="@dimen/text_14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 空状态 -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:alpha="0.3"
            android:src="@drawable/ic_empty_cart" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/cart_empty_hint"
            android:textColor="@color/textHint"
            android:textSize="@dimen/text_16sp" />

        <TextView
            android:id="@+id/tv_go_shop"
            style="@style/OptionChip"
            android:layout_marginTop="20dp"
            android:background="@drawable/selector_orange_button"
            android:paddingHorizontal="24dp"
            android:text="@string/cart_go_shop"
            android:textColor="@color/textWhite" />
    </LinearLayout>

</LinearLayout>
