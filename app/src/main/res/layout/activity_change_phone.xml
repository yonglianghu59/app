<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgMain"
    android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="@dimen/search_bar_height" android:background="@color/bgWhite" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:id="@+id/iv_back" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_back" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="修改手机号" android:textColor="@color/textPrimary" android:textSize="@dimen/text_18sp" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@color/bgWhite" android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="当前手机号" android:textColor="@color/textHint" android:textSize="@dimen/text_12sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="138****5678" android:textColor="@color/textPrimary" android:textSize="@dimen/text_16sp" />
        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginVertical="16dp" android:background="@color/bgDivider" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="新手机号" android:textColor="@color/textHint" android:textSize="@dimen/text_12sp" />
        <EditText android:id="@+id/et_new_phone" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="4dp" android:background="@drawable/bg_search_bar" android:hint="请输入新手机号" android:inputType="phone" android:paddingHorizontal="12dp" android:textSize="@dimen/text_15sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="验证码" android:textColor="@color/textHint" android:textSize="@dimen/text_12sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="4dp" android:orientation="horizontal">
            <EditText android:id="@+id/et_verify_code" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_search_bar" android:hint="请输入验证码" android:inputType="number" android:paddingHorizontal="12dp" android:textSize="@dimen/text_15sp" />
            <TextView android:id="@+id/tv_send_code" android:layout_width="100dp" android:layout_height="match_parent" android:layout_marginStart="8dp" android:background="@drawable/selector_orange_button" android:gravity="center" android:text="获取验证码" android:textColor="@color/textWhite" android:textSize="@dimen/text_12sp" />
        </LinearLayout>
        <TextView android:id="@+id/btn_confirm_phone" android:layout_width="match_parent" android:layout_height="@dimen/button_height" android:layout_marginTop="24dp" android:background="@drawable/selector_orange_button" android:gravity="center" android:text="确认修改" android:textColor="@color/textWhite" android:textSize="@dimen/text_16sp" android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
