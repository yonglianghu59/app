<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgMain"
    android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="@dimen/search_bar_height" android:background="@color/bgWhite" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <ImageView android:id="@+id/iv_back" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_back" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="修改密码" android:textColor="@color/textPrimary" android:textSize="@dimen/text_18sp" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@color/bgWhite" android:orientation="vertical" android:padding="16dp">
        <EditText android:id="@+id/et_old_password" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/bg_search_bar" android:hint="请输入当前密码" android:inputType="textPassword" android:paddingHorizontal="12dp" android:textSize="@dimen/text_15sp" />
        <EditText android:id="@+id/et_new_password" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="12dp" android:background="@drawable/bg_search_bar" android:hint="请输入新密码（6-16位）" android:inputType="textPassword" android:paddingHorizontal="12dp" android:textSize="@dimen/text_15sp" />
        <EditText android:id="@+id/et_confirm_password" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="12dp" android:background="@drawable/bg_search_bar" android:hint="请确认新密码" android:inputType="textPassword" android:paddingHorizontal="12dp" android:textSize="@dimen/text_15sp" />
        <TextView android:id="@+id/btn_confirm_password" android:layout_width="match_parent" android:layout_height="@dimen/button_height" android:layout_marginTop="24dp" android:background="@drawable/selector_orange_button" android:gravity="center" android:text="确认修改" android:textColor="@color/textWhite" android:textSize="@dimen/text_16sp" android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
