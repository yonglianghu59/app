<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bgWhite"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:layout_marginVertical="2dp">

    <ImageView android:id="@+id/iv_msg_icon" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_message" android:background="@drawable/bg_search_bar" android:padding="8dp" />

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_msg_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/textPrimary" android:textSize="@dimen/text_14sp" android:textStyle="bold" />
        <TextView android:id="@+id/tv_msg_content" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:maxLines="2" android:ellipsize="end" android:textColor="@color/textSecondary" android:textSize="@dimen/text_12sp" />
    </LinearLayout>

    <TextView android:id="@+id/tv_msg_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/textHint" android:textSize="@dimen/text_11sp" />
</LinearLayout>
