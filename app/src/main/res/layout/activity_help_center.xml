<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgMain"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/search_bar_height"
        android:background="@color/bgWhite"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">
        <ImageView android:id="@+id/iv_back" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_back" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="帮助中心" android:textColor="@color/textPrimary" android:textSize="@dimen/text_18sp" android:textStyle="bold" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="常见问题" android:textColor="@color/textPrimary" android:textSize="@dimen/text_18sp" android:textStyle="bold" />

            <TextView android:id="@+id/faq_1" style="@style/FaqItem" android:text="如何下单？" />
            <TextView android:id="@+id/faq_2" style="@style/FaqItem" android:text="配送时间是多久？" />
            <TextView android:id="@+id/faq_3" style="@style/FaqItem" android:text="如何取消订单？" />
            <TextView android:id="@+id/faq_4" style="@style/FaqItem" android:text="如何申请退款？" />
            <TextView android:id="@+id/faq_5" style="@style/FaqItem" android:text="优惠券如何使用？" />
            <TextView android:id="@+id/faq_6" style="@style/FaqItem" android:text="支付方式有哪些？" />
            <TextView android:id="@+id/faq_7" style="@style/FaqItem" android:text="如何联系客服？" />
            <TextView android:id="@+id/faq_8" style="@style/FaqItem" android:text="如何修改收货地址？" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
